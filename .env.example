# Maritime Atlas — variables d'environnement
# Copie en .env et remplis avec tes vraies valeurs

# === aisstream.io ===
# Crée un compte gratuit sur https://aisstream.io et récupère ton API key
AISSTREAM_API_KEY=your-api-key-here

# Bounding box France métropole — Manche + Atlantique + Méditerranée
# Inclut Pyrénées Atlantiques, Bretagne, Manche, Provence/Côte d'Azur, Corse.
# Volume estimé : ~250 msg/s peak (vs ~50 pour Bretagne seule). Reste OK avec
# compression+retention TimescaleDB (~5 GB total après 30j).
# Format aisstream.io : [[[swLat, swLon], [neLat, neLon]]]
AIS_BBOX_SW_LAT=41.0
AIS_BBOX_SW_LON=-6.0
AIS_BBOX_NE_LAT=51.5
AIS_BBOX_NE_LON=10.0

# === PostgreSQL + PostGIS + TimescaleDB ===
POSTGRES_USER=maritime
POSTGRES_PASSWORD=maritime
POSTGRES_DB=maritime
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === RabbitMQ ===
RABBITMQ_USER=maritime
RABBITMQ_PASSWORD=maritime
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# === GeoServer ===
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver
GEOSERVER_PORT=8080

# === Auth refonte (sprint username + Resend + RBAC) ===
# Seed admin idempotent au boot du service api. Si l'email existe déjà
# en DB, le user est promote à role=admin. Si pas en DB et ADMIN_PASSWORD
# fourni, le compte est créé avec ce mdp + email vérifié.
# Pour bootstrap : set ADMIN_PASSWORD une fois, boot, puis retirer du .env.
ADMIN_EMAIL=sylvain.ladoire@gmail.com
ADMIN_USERNAME=sylvain
ADMIN_PASSWORD=

# JWT secret long et aléatoire. Si vide en prod, le boot du api throws.
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Base URL publique — utilisée pour le lien de vérification email
# envoyé via Resend (https://<base>/auth/verify?token=...).
PUBLIC_BASE_URL=https://maritime.sladoire.dev

# Resend (Phase 2 — email verification + password reset).
# Crée un compte gratuit sur https://resend.com, ajoute ton domaine
# sladoire.dev (DNS SPF + DKIM via Cloudflare en 5 min), copie l'API key.
# Free tier = 3000 mails/mois, signup sans CB.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@sladoire.dev

# Google OAuth (Phase 3.5 — "Continuer avec Google" en complément du
# username/password). Crée un OAuth Client ID dans Google Cloud Console :
#   Console → projet → API et services → Identifiants → ID client OAuth
#   Type : Application Web
#   URI de redirection autorisés :
#     - http://localhost:4204/api/auth/google/callback   (dev SSH tunnel)
#     - https://maritime.sladoire.dev/api/auth/google/callback   (prod)
#   Origines JavaScript autorisées : mêmes domaines sans /api/...
#   Audience → utilisateurs test : ajoute ton email (sinon refusé en test mode)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://maritime.sladoire.dev/api/auth/google/callback

# === Cloudflare Tunnel (sprint déploiement public, sprint exposition) ===
# Pour exposer maritime-atlas en HTTPS sur https://maritime.sladoire.dev via
# Cloudflare Tunnel (zero-trust, pas d'ouverture de port sur le NAS).
#
# Étapes pour obtenir le token :
#   1. https://one.dash.cloudflare.com/ → Networks → Tunnels → Create a tunnel
#   2. Connector: Cloudflared. Name: `maritime-atlas-nas`. Save.
#   3. Copie ce qu'il y a après `--token` dans la commande proposée
#   4. Onglet "Public Hostname" → Add a public hostname :
#        Subdomain: maritime  ·  Domain: sladoire.dev
#        Type: HTTP  ·  URL: frontend:80
#      (le `frontend` est le DNS interne docker, le container nginx du
#       maritime-atlas/frontend qui proxy déjà /api/ + /geoserver/.)
#   5. Save
CLOUDFLARE_TUNNEL_TOKEN=eyJ...paste-token-here
