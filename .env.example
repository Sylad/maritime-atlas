# Maritime Atlas — variables d'environnement
# Copie en .env et remplis avec tes vraies valeurs

# === aisstream.io ===
# Crée un compte gratuit sur https://aisstream.io et récupère ton API key
AISSTREAM_API_KEY=your-api-key-here

# Bounding box France métropole — Manche + Atlantique + Méditerranée
# Inclut Pyrénées Atlantiques, Bretagne, Manche, Provence/Côte d'Azur, Corse.
# Volume estimé : ~250 msg/s peak (vs ~50 pour Bretagne seule). Reste OK avec
# compression+retention TimescaleDB (~5 GB total après 30j).
# Format aisstream.io : [[[swLat, swLon], [neLat, neLon]]]
AIS_BBOX_SW_LAT=41.0
AIS_BBOX_SW_LON=-6.0
AIS_BBOX_NE_LAT=51.5
AIS_BBOX_NE_LON=10.0

# === PostgreSQL + PostGIS + TimescaleDB ===
POSTGRES_USER=maritime
POSTGRES_PASSWORD=maritime
POSTGRES_DB=maritime
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === RabbitMQ ===
RABBITMQ_USER=maritime
RABBITMQ_PASSWORD=maritime
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# === GeoServer ===
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver
GEOSERVER_PORT=8080
